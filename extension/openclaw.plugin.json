{
  "id": "daily-system",
  "uiHints": {
    "enabled": {
      "label": "启用 Daily System Runtime"
    },
    "systemRoot": {
      "label": "系统根目录",
      "help": "包含 deploy/start.sh、deploy/stop.sh、deploy/status.sh 的目录"
    },
    "defaultExposeMode": {
      "label": "默认暴露模式",
      "help": "local=仅本地，tunnel=Cloudflare 外网"
    },
    "workspacePath": {
      "label": "Daily Workspace 路径",
      "help": "用于读取 config.json 并写入 HEARTBEAT.md"
    },
    "boardPath": {
      "label": "白板任务文件路径",
      "help": "多 agent 协作任务板，默认 /tmp/daily-system-board/tasks.json"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "systemRoot": {
        "type": "string"
      },
      "defaultExposeMode": {
        "type": "string",
        "enum": [
          "local",
          "tunnel"
        ],
        "default": "local"
      },
      "workspacePath": {
        "type": "string"
      },
      "boardPath": {
        "type": "string",
        "default": "/tmp/daily-system-board/tasks.json"
      }
    }
  }
}
